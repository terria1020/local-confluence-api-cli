# Confluence API CLI - Environment Variables
# .env.example → .env 로 복사 후 값을 채워주세요

# Atlassian 도메인 (예: yourcompany.atlassian.net)
CONFLUENCE_DOMAIN=yourcompany.atlassian.net

# Atlassian 계정 이메일
CONFLUENCE_EMAIL=you@example.com

# Atlassian API 토큰
# 발급: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your_api_token_here

# 로그 레벨 (debug, info, warn, error) — 기본: info
# LOG_LEVEL=info
